{
  "name": "bare-stow-target-pear-runtime",
  "version": "0.0.0",
  "description": "Pear Runtime target for bare-stow",
  "exports": {
    "./package": "./package.json",
    ".": "./index.js"
  },
  "files": [
    "index.js"
  ],
  "scripts": {
    "format": "prettier --write . && lunte --fix",
    "lint": "prettier --check . && lunte",
    "test": "npm run test:bare && npm run test:node",
    "test:bare": "brittle-bare --coverage test.js",
    "test:node": "brittle-node --coverage test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/holepunchto/bare-stow-target-pear-runtime.git"
  },
  "author": "Holepunch",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/holepunchto/bare-stow-target-pear-runtime/issues"
  },
  "homepage": "https://github.com/holepunchto/bare-stow-target-pear-runtime#readme",
  "devDependencies": {
    "brittle": "^4.0.2",
    "lunte": "^1.7.0",
    "prettier": "^3.3.3",
    "prettier-config-holepunch": "^2.0.0"
  }
}
